# ─────────────────────────────────────────────
#  REQUIRED
# ─────────────────────────────────────────────

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LinkedIn OAuth 2.0 — create an app at https://developer.linkedin.com
# Required scopes: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# Must match what you set in your LinkedIn app's Auth settings
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback

# ─────────────────────────────────────────────
#  OPTIONAL
# ─────────────────────────────────────────────

# Generate with: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_string

PORT=3000

# Password to protect the approval UI
UI_PASSWORD=changeme

# Reddit API (optional — improves rate limits)
# Register at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
