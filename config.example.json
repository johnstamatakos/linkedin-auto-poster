{
  "sources": {
    "hackernews": {
      "enabled": true,
      "queries": [
        "Add your HN search queries here",
        "e.g. LLM API",
        "e.g. platform engineering",
        "e.g. AI agents"
      ],
      "minScore": 50,
      "maxAgeHours": 72
    },
    "reddit": {
      "enabled": true,
      "subreddits": [
        "MachineLearning",
        "programming",
        "SoftwareEngineering"
      ],
      "minScore": 50,
      "maxAgeHours": 72
    },
    "rss": {
      "enabled": true,
      "feeds": [
        { "name": "Simon Willison",      "url": "https://simonwillison.net/atom/everything/" },
        { "name": "Martin Fowler",       "url": "https://martinfowler.com/feed.atom" },
        { "name": "Pragmatic Engineer",  "url": "https://newsletter.pragmaticengineer.com/feed" },
        { "name": "High Scalability",    "url": "https://highscalability.com/rss/" },
        { "name": "LeadDev",             "url": "https://leaddev.com/feed" }
      ],
      "maxAgeHours": 168
    }
  },
  "pipeline": {
    "articlesPerCrawlRun": 60,
    "maxDraftsPerRun": 3,
    "minRelevanceScore": 7,
    "linkedInPostMaxChars": 2800
  },
  "schedule": {
    "crawlCron": "0 8 * * 1,3,5",
    "postCron": "0 9 * * 2",
    "analyticsCron": "0 10 * * *",
    "timezone": "America/New_York"
  }
}
